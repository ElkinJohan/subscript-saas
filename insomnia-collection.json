{
  "_type": "export",
  "__export_format": 4,
  "__export_date": "2026-04-23T00:00:00.000Z",
  "__export_source": "subscript-saas",
  "resources": [
    {
      "_id": "wrk_subscript",
      "_type": "workspace",
      "name": "Subscript SaaS",
      "description": "API collection for Subscript SaaS — membership management backend",
      "scope": "collection"
    },
    {
      "_id": "env_base",
      "_type": "environment",
      "parentId": "wrk_subscript",
      "name": "Local",
      "data": {
        "base_url": "http://localhost:8080",
        "access_token": "",
        "refresh_token": "",
        "owner_id": "",
        "client_id": "",
        "plan_id": "",
        "subscription_id": "",
        "payment_id": ""
      },
      "color": "#4CAF50",
      "isPrivate": false
    },

    {
      "_id": "fld_auth",
      "_type": "request_group",
      "parentId": "wrk_subscript",
      "name": "Auth",
      "description": "Authentication endpoints"
    },
    {
      "_id": "req_login",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Login",
      "method": "POST",
      "url": "{{ _.base_url }}/api/auth/login",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"owner@gym.com\",\n  \"password\": \"secret123\"\n}"
      },
      "description": "Returns access_token (15 min) and refresh_token (7 days)"
    },

    {
      "_id": "fld_owners",
      "_type": "request_group",
      "parentId": "wrk_subscript",
      "name": "Owners",
      "description": "Owner (business) management"
    },
    {
      "_id": "req_owner_register",
      "_type": "request",
      "parentId": "fld_owners",
      "name": "Register Owner",
      "method": "POST",
      "url": "{{ _.base_url }}/api/owners",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"nit\": \"900123456-1\",\n  \"name\": \"Carlos Pérez\",\n  \"email\": \"owner@gym.com\",\n  \"phone\": \"3001234567\",\n  \"businessName\": \"Gym Élite\",\n  \"gracePeriodDays\": 3,\n  \"password\": \"secret123\"\n}"
      },
      "description": "Public endpoint — no token required"
    },
    {
      "_id": "req_owner_find",
      "_type": "request",
      "parentId": "fld_owners",
      "name": "Find Owner by ID",
      "method": "GET",
      "url": "{{ _.base_url }}/api/owners/{{ _.owner_id }}",
      "headers": [
        { "name": "Authorization", "value": "Bearer {{ _.access_token }}" }
      ],
      "body": { "mimeType": "application/json" },
      "description": "Requires Bearer token"
    },

    {
      "_id": "fld_clients",
      "_type": "request_group",
      "parentId": "wrk_subscript",
      "name": "Clients",
      "description": "Client management under an Owner"
    },
    {
      "_id": "req_client_register",
      "_type": "request",
      "parentId": "fld_clients",
      "name": "Register Client",
      "method": "POST",
      "url": "{{ _.base_url }}/api/owners/{{ _.owner_id }}/clients",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ _.access_token }}" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"cedula\": \"1234567890\",\n  \"name\": \"Juan García\",\n  \"email\": \"juan@example.com\",\n  \"phone\": \"3109876543\"\n}"
      }
    },
    {
      "_id": "req_client_find_by_owner",
      "_type": "request",
      "parentId": "fld_clients",
      "name": "Find Clients by Owner",
      "method": "GET",
      "url": "{{ _.base_url }}/api/owners/{{ _.owner_id }}/clients",
      "headers": [
        { "name": "Authorization", "value": "Bearer {{ _.access_token }}" }
      ],
      "body": { "mimeType": "application/json" }
    },
    {
      "_id": "req_client_deactivate",
      "_type": "request",
      "parentId": "fld_clients",
      "name": "Deactivate Client",
      "method": "PATCH",
      "url": "{{ _.base_url }}/api/clients/{{ _.client_id }}/deactivate",
      "headers": [
        { "name": "Authorization", "value": "Bearer {{ _.access_token }}" }
      ],
      "body": { "mimeType": "application/json" }
    },

    {
      "_id": "fld_plans",
      "_type": "request_group",
      "parentId": "wrk_subscript",
      "name": "Plans",
      "description": "Membership plan management"
    },
    {
      "_id": "req_plan_create",
      "_type": "request",
      "parentId": "fld_plans",
      "name": "Create Plan",
      "method": "POST",
      "url": "{{ _.base_url }}/api/owners/{{ _.owner_id }}/plans",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ _.access_token }}" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"name\": \"Mensual\",\n  \"description\": \"Acceso completo al gimnasio por 30 días\",\n  \"priceAmount\": 80000,\n  \"priceCurrency\": \"COP\",\n  \"durationDays\": 30\n}"
      }
    },
    {
      "_id": "req_plan_find_by_owner",
      "_type": "request",
      "parentId": "fld_plans",
      "name": "Find Plans by Owner",
      "method": "GET",
      "url": "{{ _.base_url }}/api/owners/{{ _.owner_id }}/plans",
      "headers": [
        { "name": "Authorization", "value": "Bearer {{ _.access_token }}" }
      ],
      "body": { "mimeType": "application/json" }
    },
    {
      "_id": "req_plan_deactivate",
      "_type": "request",
      "parentId": "fld_plans",
      "name": "Deactivate Plan",
      "method": "PATCH",
      "url": "{{ _.base_url }}/api/plans/{{ _.plan_id }}/deactivate",
      "headers": [
        { "name": "Authorization", "value": "Bearer {{ _.access_token }}" }
      ],
      "body": { "mimeType": "application/json" }
    },

    {
      "_id": "fld_subscriptions",
      "_type": "request_group",
      "parentId": "wrk_subscript",
      "name": "Subscriptions",
      "description": "Subscription lifecycle management"
    },
    {
      "_id": "req_subscription_create",
      "_type": "request",
      "parentId": "fld_subscriptions",
      "name": "Create Subscription",
      "method": "POST",
      "url": "{{ _.base_url }}/api/subscriptions",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ _.access_token }}" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"clientId\": \"{{ _.client_id }}\",\n  \"planId\": \"{{ _.plan_id }}\"\n}"
      }
    },
    {
      "_id": "req_subscription_by_client",
      "_type": "request",
      "parentId": "fld_subscriptions",
      "name": "Find Subscriptions by Client",
      "method": "GET",
      "url": "{{ _.base_url }}/api/subscriptions/client/{{ _.client_id }}",
      "headers": [
        { "name": "Authorization", "value": "Bearer {{ _.access_token }}" }
      ],
      "body": { "mimeType": "application/json" }
    },
    {
      "_id": "req_subscription_active",
      "_type": "request",
      "parentId": "fld_subscriptions",
      "name": "Find Active Subscription",
      "method": "GET",
      "url": "{{ _.base_url }}/api/subscriptions/client/{{ _.client_id }}/active",
      "headers": [
        { "name": "Authorization", "value": "Bearer {{ _.access_token }}" }
      ],
      "body": { "mimeType": "application/json" }
    },
    {
      "_id": "req_subscription_cancel",
      "_type": "request",
      "parentId": "fld_subscriptions",
      "name": "Cancel Subscription",
      "method": "POST",
      "url": "{{ _.base_url }}/api/subscriptions/{{ _.subscription_id }}/cancel",
      "headers": [
        { "name": "Authorization", "value": "Bearer {{ _.access_token }}" }
      ],
      "body": { "mimeType": "application/json" }
    },
    {
      "_id": "req_subscription_renew",
      "_type": "request",
      "parentId": "fld_subscriptions",
      "name": "Renew Subscription",
      "method": "POST",
      "url": "{{ _.base_url }}/api/subscriptions/{{ _.subscription_id }}/renew",
      "headers": [
        { "name": "Authorization", "value": "Bearer {{ _.access_token }}" }
      ],
      "body": { "mimeType": "application/json" }
    },

    {
      "_id": "fld_payments",
      "_type": "request_group",
      "parentId": "wrk_subscript",
      "name": "Payments",
      "description": "Payment registration and lookup"
    },
    {
      "_id": "req_payment_register",
      "_type": "request",
      "parentId": "fld_payments",
      "name": "Register Payment",
      "method": "POST",
      "url": "{{ _.base_url }}/api/payments",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ _.access_token }}" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"subscriptionId\": \"{{ _.subscription_id }}\",\n  \"registeredBy\": \"{{ _.owner_id }}\"\n}"
      }
    },
    {
      "_id": "req_payment_by_subscription",
      "_type": "request",
      "parentId": "fld_payments",
      "name": "Find Payments by Subscription",
      "method": "GET",
      "url": "{{ _.base_url }}/api/payments/subscription/{{ _.subscription_id }}",
      "headers": [
        { "name": "Authorization", "value": "Bearer {{ _.access_token }}" }
      ],
      "body": { "mimeType": "application/json" }
    }
  ]
}
